# Copy this file to .env.playwright and fill in your test credentials.
# These should be a dedicated test Supabase account — NOT your production account.
#
# Run once to generate auth state:
#   npx dotenv -e .env.playwright -- npx playwright test --project=setup
#
# Then run all E2E tests:
#   npx dotenv -e .env.playwright -- npx playwright test

TEST_EMAIL=test@example.com
TEST_PASSWORD=yourTestPassword

# Optional — defaults to http://localhost:3000
BASE_URL=http://localhost:3000
